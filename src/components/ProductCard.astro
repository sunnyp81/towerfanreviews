---
import { type Product } from '@data/products';
import FanIllustration from './FanIllustration.astro';
import RatingStars from './RatingStars.astro';
import AffiliateButton from './AffiliateButton.astro';
interface Props { product: Product; rank?: number; }
const { product, rank } = Astro.props;
const p = product;
const topSpecs = p.specs.slice(0, 3);
---
<article class="group relative flex flex-col rounded-2xl bg-white border border-breeze-100 shadow-card card-lift overflow-hidden">
  {p.award && (
    <span class="absolute left-4 top-4 z-10 rounded-full bg-breeze-900 text-white text-[0.7rem] font-display font-semibold uppercase tracking-wide px-3 py-1 shadow">{p.award}</span>
  )}
  {rank && (
    <span class="absolute right-4 top-4 z-10 grid place-items-center w-9 h-9 rounded-full bg-heat-700 text-white font-display font-bold text-sm shadow-glow">{rank}</span>
  )}

  <div class="relative bg-breeze-mesh px-6 pt-8 pb-4 grid place-items-center">
    {p.image
      ? <img src={p.image} alt={`${p.name} tower fan`} width="180" height="234" loading="lazy" decoding="async" class="h-44 w-auto object-contain drop-shadow" />
      : <FanIllustration variant={p.illustration ?? 'standard'} class="h-44 w-auto" label={`${p.name} tower fan`} />}
  </div>

  <div class="flex flex-col gap-3 p-5 flex-1">
    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-breeze-600">{p.brand}</p>
      <h3 class="text-lg leading-snug mt-0.5">
        {p.hasReview ? <a href={`/${p.slug}/`} class="hover:text-breeze-700">{p.name}</a> : p.name}
      </h3>
    </div>

    <div class="flex items-center justify-between">
      <RatingStars rating={p.rating} size="sm" />
      {p.priceGBP && <span class="font-display font-bold text-ink-900">~£{p.priceGBP}</span>}
    </div>

    <p class="text-sm text-ink-500 leading-relaxed">{p.verdict}</p>

    <ul class="mt-1 space-y-1.5 text-sm text-ink-700">
      {topSpecs.map((s) => (
        <li class="flex gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#06a4c4" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <span><strong class="text-ink-900 font-medium">{s.label}:</strong> {s.value}</span>
        </li>
      ))}
    </ul>

    <div class="mt-auto pt-3 flex flex-col gap-2">
      <AffiliateButton product={p} block />
      {p.hasReview && <a href={`/${p.slug}/`} class="text-sm font-semibold text-breeze-700 hover:text-heat-700 text-center">Read full review →</a>}
    </div>
  </div>
</article>
