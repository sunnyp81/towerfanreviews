---
interface Props { faqs: { q: string; a: string }[]; heading?: string; }
const { faqs, heading = 'Frequently asked questions' } = Astro.props;
if (!faqs.length) return null;
---
<section class="not-prose my-10">
  <h2 class="text-2xl mb-5">{heading}</h2>
  <div class="space-y-3">
    {faqs.map((f, i) => (
      <details class="group rounded-xl border border-breeze-100 bg-white shadow-card open:shadow-lift transition-shadow" name="faq" open={i === 0}>
        <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 font-display font-semibold text-ink-900 list-none">
          <span>{f.q}</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#06a4c4" stroke-width="2.5" stroke-linecap="round" class="shrink-0 transition-transform group-open:rotate-45" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
        </summary>
        <div class="px-5 pb-5 -mt-1 text-ink-700 leading-relaxed text-[0.97rem]" set:html={f.a} />
      </details>
    ))}
  </div>
</section>
