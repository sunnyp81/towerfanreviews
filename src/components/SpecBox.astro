---
import { type Product } from '@data/products';
import FanIllustration from './FanIllustration.astro';
import RatingStars from './RatingStars.astro';
import AffiliateButton from './AffiliateButton.astro';
interface Props { product: Product; }
const { product: p } = Astro.props;
---
<aside class="not-prose rounded-2xl border border-breeze-100 bg-white shadow-lift overflow-hidden">
  <div class="grid md:grid-cols-[260px_1fr]">
    <div class="relative bg-breeze-mesh grid place-items-center p-6">
      {p.award && <span class="absolute left-4 top-4 rounded-full bg-heat-500 text-white text-[0.7rem] font-display font-semibold uppercase tracking-wide px-3 py-1 shadow-glow">{p.award}</span>}
      {p.image
        ? <img src={p.image} alt={`${p.name} tower fan`} width="200" height="260" class="h-52 w-auto object-contain drop-shadow" />
        : <FanIllustration variant={p.illustration ?? 'standard'} class="h-52 w-auto" label={`${p.name} tower fan`} />}
    </div>
    <div class="p-6 flex flex-col gap-4">
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-breeze-600">{p.brand} · Our verdict</p>
          <div class="mt-1 flex items-center gap-3">
            <RatingStars rating={p.rating} size="lg" />
          </div>
        </div>
        {p.priceGBP && <div class="text-right"><span class="block text-xs text-ink-400 uppercase tracking-wide">Typical price</span><span class="font-display font-bold text-2xl text-ink-900">~£{p.priceGBP}</span></div>}
      </div>

      <p class="text-ink-700 leading-relaxed text-[0.97rem]">{p.verdict}</p>

      <dl class="grid grid-cols-2 gap-x-4 gap-y-2 text-sm border-t border-breeze-50 pt-4">
        <div class="col-span-2"><dt class="inline text-ink-400">Best for: </dt><dd class="inline font-medium text-ink-900">{p.bestFor}</dd></div>
        {p.specs.slice(0, 6).map((s) => (
          <div><dt class="text-ink-400 text-xs uppercase tracking-wide">{s.label}</dt><dd class="font-medium text-ink-900">{s.value}</dd></div>
        ))}
      </dl>

      <div class="mt-auto pt-2 flex flex-wrap gap-3">
        <AffiliateButton product={p} label="Check price on Amazon" />
        <span class="text-xs text-ink-400 self-center">Price &amp; availability updated regularly</span>
      </div>
    </div>
  </div>
</aside>
