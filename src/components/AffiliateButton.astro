---
import { affiliateUrl, type Product } from '@data/products';
interface Props { product: Product; label?: string; block?: boolean; variant?: 'cta' | 'ghost'; class?: string; }
const { product, label = 'Check price on Amazon', block = false, variant = 'cta', class: cls = '' } = Astro.props;
const url = affiliateUrl(product);
---
<a
  href={url}
  target="_blank"
  rel="nofollow sponsored noopener noreferrer"
  class={`btn ${variant === 'cta' ? 'btn-cta' : 'btn-ghost'} ${block ? 'w-full' : ''} ${cls}`}
  data-affiliate="amazon"
>
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M3 6h2l2.4 12.3a1 1 0 0 0 1 .8h8.7a1 1 0 0 0 1-.78L21 8H6"/><circle cx="9" cy="21" r="1.4"/><circle cx="18" cy="21" r="1.4"/></svg>
  <span>{label}</span>
</a>
