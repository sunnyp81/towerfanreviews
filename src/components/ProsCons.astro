---
interface Props { pros: string[]; cons: string[]; }
const { pros, cons } = Astro.props;
---
<div class="not-prose grid sm:grid-cols-2 gap-4 my-7">
  <div class="rounded-2xl border border-emerald-200 bg-emerald-50/60 p-5">
    <h3 class="flex items-center gap-2 font-display font-semibold text-emerald-800 text-base m-0">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 10v12"/><path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2.76a2 2 0 0 0 1.79-1.11L12 2a3.13 3.13 0 0 1 3 3.88Z"/></svg>
      Pros
    </h3>
    <ul class="mt-3 space-y-2">
      {pros.map((x) => (
        <li class="flex gap-2 text-sm text-ink-700"><span class="text-emerald-600 mt-0.5">✓</span><span>{x}</span></li>
      ))}
    </ul>
  </div>
  <div class="rounded-2xl border border-rose-200 bg-rose-50/60 p-5">
    <h3 class="flex items-center gap-2 font-display font-semibold text-rose-800 text-base m-0">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 14V2"/><path d="M9 18.12 10 14H4.17a2 2 0 0 1-1.92-2.56l2.33-8A2 2 0 0 1 6.5 2H20a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-2.76a2 2 0 0 0-1.79 1.11L12 22a3.13 3.13 0 0 1-3-3.88Z"/></svg>
      Cons
    </h3>
    <ul class="mt-3 space-y-2">
      {cons.map((x) => (
        <li class="flex gap-2 text-sm text-ink-700"><span class="text-rose-500 mt-0.5">✕</span><span>{x}</span></li>
      ))}
    </ul>
  </div>
</div>
