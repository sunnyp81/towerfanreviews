---
// Fonts are self-hosted: the previous fonts.googleapis.com <link rel=stylesheet>
// was render-blocking on a third-party origin, with a second hop to fonts.gstatic.com.
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/sora/600.css';
import '@fontsource/sora/700.css';
import '@fontsource/sora/800.css';
import '../styles/global.css';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { SITE, GA4_ID, canonical } from '@lib/seo';

interface Props {
  title: string;
  description: string;
  path?: string;
  schema?: object | null;
  ogImage?: string;
  noindex?: boolean;
}
const { title, description, path = Astro.url.pathname, schema = null, ogImage, noindex = false } = Astro.props;
const url = canonical(path);
// Keep rendered <title> <= 60 chars: append brand only if it fits, else a short suffix, else bare.
function buildTitle(t: string): string {
  if (t.includes(SITE.name)) return t;
  const full = `${t} | ${SITE.name}`;
  if (full.length <= 60) return full;
  const short = `${t} | TFR`;
  if (short.length <= 60) return short;
  return t;
}
const fullTitle = buildTitle(title);
const og = ogImage ?? '/og-default.png';
---
<!doctype html>
<html lang="en-GB">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={url} />
  {noindex && <meta name="robots" content="noindex, follow" />}
  <meta name="theme-color" content="#06a4c4" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={SITE.name} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={url} />
  <meta property="og:locale" content="en_GB" />
  <meta property="og:image" content={canonical(og)} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={canonical(og)} />

  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="sitemap" href="/sitemap-index.xml" />

  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

  {GA4_ID && (
    <Fragment>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
      <script is:inline define:vars={{ GA4_ID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', GA4_ID, { anonymize_ip: true });
      </script>
    </Fragment>
  )}
    <!-- GA4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-DQ0N4L2LC8"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-DQ0N4L2LC8');
    </script>
  </head>
<body class="min-h-screen flex flex-col bg-frost">
  <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:z-[100] focus:top-3 focus:left-3 focus:bg-white focus:px-4 focus:py-2 focus:rounded-lg focus:shadow-lift focus:text-breeze-700 focus:font-semibold">Skip to content</a>
  <Header />
  <main id="main" class="flex-1">
    <slot />
  </main>
  <Footer />
</body>
</html>
