---
import { getCollection } from 'astro:content';
import Base from '@layouts/Base.astro';
import FanIllustration from '@components/FanIllustration.astro';
import ProductCard from '@components/ProductCard.astro';
import RatingStars from '@components/RatingStars.astro';
import EmailCapture from '@components/EmailCapture.astro';
import { products } from '@data/products';
import { SITE, graph, orgSchema, websiteSchema, canonical } from '@lib/seo';

const topPicks = [...products].sort((a, b) => b.rating - a.rating).slice(0, 6);

const articles = (await getCollection('articles')).filter((a) => !a.data.draft);
const latestReviews = articles
  .filter((a) => a.data.kind === 'review')
  .sort((a, b) => (b.data.updatedDate ?? b.data.publishDate).valueOf() - (a.data.updatedDate ?? a.data.publishDate).valueOf())
  .slice(0, 4);

const categories = [
  { name: 'Best Overall', href: '/best-tower-fans/', icon: 'star', desc: 'Our top tower fans for UK homes', variant: 'standard' as const },
  { name: 'Bladeless', href: '/best-bladeless-tower-fans/', icon: 'wind', desc: 'Sleek, child-safe, easy to clean', variant: 'bladeless' as const },
  { name: 'Hot & Cold', href: '/best-tower-fan-heaters/', icon: 'flame', desc: 'Year-round heating and cooling', variant: 'heater' as const },
  { name: 'Quiet', href: '/best-quiet-tower-fans/', icon: 'moon', desc: 'Whisper-quiet for bedrooms', variant: 'tall' as const },
  { name: 'With Remote', href: '/best-tower-fans-with-remote/', icon: 'zap', desc: 'Control from the sofa or bed', variant: 'standard' as const },
  { name: 'Mini & Desk', href: '/best-mini-tower-fans/', icon: 'box', desc: 'Compact cooling for small spaces', variant: 'mini' as const },
];

const brands = ['Dyson', 'Dreo', 'Levoit', 'Honeywell', 'Dimplex', 'Shark', 'Silvercrest', 'MeacoFan'];

// Hero stats must be counted, never asserted. See /how-we-rate/.
const brandCount = new Set(products.map((p) => p.brand)).size;
const guideCount = articles.filter((a) => a.data.kind === 'guide' || a.data.kind === 'roundup').length;

const schema = graph(orgSchema(), websiteSchema());
---
<Base
  title="Tower Fan Reviews: Best UK Tower Fans Compared 2026"
  description={SITE.description}
  path="/"
  schema={schema}
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-breeze-mesh">
    <div class="absolute inset-0 bg-dot-grid opacity-50" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-6xl px-4 pt-16 pb-20 grid lg:grid-cols-[1.15fr_0.85fr] gap-10 items-center">
      <div class="fade-up">
        <span class="inline-flex items-center gap-2 rounded-full bg-white/70 backdrop-blur px-3.5 py-1.5 text-sm font-medium text-breeze-700 border border-breeze-100">
          <span class="w-2 h-2 rounded-full bg-emerald-500"></span> Independent · No manufacturer funding
        </span>
        <h1 class="mt-5 text-5xl sm:text-6xl leading-[1.02]">
          Find the <span class="text-gradient">perfect tower fan</span> for your home
        </h1>
        <p class="mt-5 text-lg sm:text-xl text-ink-500 leading-relaxed max-w-xl">
          We compare UK tower fans on published specs, verified owner reviews and the running costs we work out ourselves, so you can stay cool without overpaying.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/best-tower-fans/" class="btn btn-cta text-base">See the best tower fans</a>
          <a href="/tower-fan-buying-guide/" class="btn btn-ghost text-base">Read the buying guide</a>
        </div>
        <dl class="mt-10 flex flex-wrap gap-x-10 gap-y-4">
          <div><dt class="text-sm text-ink-400">Fans compared</dt><dd class="font-display font-bold text-2xl text-ink-900">{products.length}</dd></div>
          <div><dt class="text-sm text-ink-400">Brands covered</dt><dd class="font-display font-bold text-2xl text-ink-900">{brandCount}</dd></div>
          <div><dt class="text-sm text-ink-400">Guides published</dt><dd class="font-display font-bold text-2xl text-ink-900">{guideCount}</dd></div>
        </dl>
      </div>

      <div class="relative hidden lg:block">
        <div class="absolute inset-0 -m-6 rounded-[2.5rem] bg-white/40 backdrop-blur-sm border border-white/60 shadow-lift" aria-hidden="true"></div>
        <div class="relative grid grid-cols-2 gap-4 p-6">
          <div class="glass rounded-2xl p-4 card-lift translate-y-3"><FanIllustration variant="bladeless" class="h-40 w-full" /><p class="text-center text-sm font-semibold mt-2 text-ink-700">Bladeless</p></div>
          <div class="glass rounded-2xl p-4 card-lift -translate-y-3"><FanIllustration variant="tall" class="h-40 w-full" /><p class="text-center text-sm font-semibold mt-2 text-ink-700">Oscillating</p></div>
          <div class="glass rounded-2xl p-4 card-lift -translate-y-2"><FanIllustration variant="heater" class="h-40 w-full" /><p class="text-center text-sm font-semibold mt-2 text-ink-700">Hot &amp; cold</p></div>
          <div class="glass rounded-2xl p-4 card-lift translate-y-2"><FanIllustration variant="mini" class="h-40 w-full" /><p class="text-center text-sm font-semibold mt-2 text-ink-700">Mini &amp; desk</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="border-y border-breeze-100 bg-white">
    <div class="mx-auto max-w-6xl px-4 py-5 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm text-ink-500">
      {[
        ['Specs and owner reviews, compared', 'M12 8v4l3 2'],
        ['Updated for the 2026 heatwave season', 'M12 2v4M12 18v4M2 12h4M18 12h4'],
        ['No paid placements, ever', 'm9 12 2 2 4-4'],
        ['Running-cost calculations included', 'M3 3v18h18'],
      ].map(([label, d]) => (
        <span class="inline-flex items-center gap-2"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#06a4c4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d={d}/></svg>{label}</span>
      ))}
    </div>
  </section>

  <!-- CATEGORY BENTO -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="flex items-end justify-between gap-4 flex-wrap mb-8">
      <div>
        <h2 class="text-3xl sm:text-4xl">Shop by what matters to you</h2>
        <p class="mt-2 text-ink-500">Whatever you need from a tower fan, we have a top pick for it.</p>
      </div>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {categories.map((c) => (
        <a href={c.href} class="group relative overflow-hidden rounded-2xl border border-breeze-100 bg-white p-6 card-lift">
          <div class="absolute -right-6 -bottom-6 opacity-[0.07] group-hover:opacity-[0.13] transition-opacity"><FanIllustration variant={c.variant} class="h-36 w-36" /></div>
          <div class="relative">
            <span class="grid place-items-center w-11 h-11 rounded-xl bg-breeze-50 text-breeze-600 mb-4">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2 15 9l7 .5-5.5 4.5L18 21l-6-3.8L6 21l1.5-7L2 9.5 9 9z"/></svg>
            </span>
            <h3 class="text-xl">{c.name}</h3>
            <p class="mt-1.5 text-sm text-ink-500">{c.desc}</p>
            <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-breeze-700 group-hover:text-heat-700">View picks <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- TOP PICKS -->
  {topPicks.length > 0 && (
    <section class="bg-mist border-y border-breeze-100">
      <div class="mx-auto max-w-6xl px-4 py-16">
        <div class="flex items-end justify-between gap-4 flex-wrap mb-8">
          <div>
            <p class="text-sm font-semibold uppercase tracking-wide text-breeze-600">Editor's choice</p>
            <h2 class="text-3xl sm:text-4xl mt-1">This season's top-rated tower fans</h2>
          </div>
          <a href="/best-tower-fans/" class="btn btn-ghost">See all top picks</a>
        </div>
        {/* These cards are the first affiliate links on the homepage, so the disclosure
            has to come before them, not just in the footer. */}
        <p class="mb-6 rounded-lg border border-breeze-100 bg-white px-4 py-3 text-sm text-ink-700">
          We may earn a commission if you buy through links below, at no extra cost to you. As an Amazon Associate we earn from qualifying purchases. <a href="/how-we-rate/" class="font-medium text-breeze-700 underline underline-offset-2">How we rate fans</a>.
        </p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {topPicks.map((p, i) => <ProductCard product={p} rank={i + 1} />)}
        </div>
      </div>
    </section>
  )}

  <!-- LATEST REVIEWS -->
  {latestReviews.length > 0 && (
    <section class="mx-auto max-w-6xl px-4 py-16">
      <h2 class="text-3xl sm:text-4xl mb-8">Latest reviews</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {latestReviews.map((a) => (
          <a href={`/${a.id}/`} class="rounded-2xl border border-breeze-100 bg-white p-5 card-lift">
            <p class="text-xs font-semibold uppercase tracking-wide text-breeze-600">Review</p>
            <h3 class="text-lg mt-1.5 leading-snug">{a.data.title}</h3>
            <p class="mt-2 text-sm text-ink-500 line-clamp-3">{a.data.description}</p>
            <span class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-breeze-700">Read review →</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- HOW WE RATE -->
  <section class="mx-auto max-w-6xl px-4 py-8">
    <div class="rounded-3xl bg-breeze-900 text-white overflow-hidden relative">
      <div class="absolute inset-0 bg-dot-grid opacity-20" aria-hidden="true"></div>
      <div class="relative grid lg:grid-cols-2 gap-8 p-8 sm:p-12 items-center">
        <div>
          <h2 class="text-white text-3xl">How we rate tower fans</h2>
          <p class="mt-3 text-breeze-100/90 leading-relaxed">We do not run a test lab. We rate every fan on the things that actually matter in a British summer, using published specifications, verified owner reviews and running costs we calculate ourselves.</p>
          <a href="/how-we-rate/" class="btn btn-cta mt-6">Our research method</a>
        </div>
        <ul class="grid sm:grid-cols-2 gap-4">
          {[
            ['Airflow', 'Stated reach and oscillation coverage'],
            ['Noise', 'Manufacturer figures and owner reports'],
            ['Running cost', 'Pence-per-hour we work out ourselves'],
            ['Build & features', 'Timers, remotes, app control and safety'],
          ].map(([t, d]) => (
            <li class="rounded-xl bg-white/10 p-4 border border-white/10"><p class="font-display font-semibold text-white">{t}</p><p class="text-sm text-breeze-100/80 mt-1">{d}</p></li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- BRANDS -->
  <section class="mx-auto max-w-6xl px-4 py-14">
    <p class="text-center text-sm font-semibold uppercase tracking-wide text-ink-400 mb-6">Brands we cover</p>
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
      {brands.map((b) => <span class="font-display font-bold text-xl text-ink-400/70 hover:text-breeze-600 transition-colors">{b}</span>)}
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-4 pb-16"><EmailCapture /></div>
</Base>
