---
import Base from '@layouts/Base.astro';
---
<Base title="Thank You" description="Thanks for getting in touch with Tower Fan Reviews." path="/thank-you/" noindex={true}>
  <div class="mx-auto max-w-2xl px-4 py-20 text-center">
    <h1 class="text-4xl sm:text-5xl">Thank you</h1>
    <p class="mt-4 text-lg text-ink-500">We have received your message. If you asked us a question we will reply by email, usually within a few days.</p>
    <p class="mt-2 text-ink-500">Signed up to the newsletter? You can unsubscribe from any email we send, or just <a href="/contact/" class="text-breeze-700 underline underline-offset-2">ask us to remove you</a>.</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/" class="btn btn-cta">Back to home</a>
      <a href="/best-tower-fans/" class="btn btn-ghost">See the best tower fans</a>
    </div>
  </div>
</Base>
