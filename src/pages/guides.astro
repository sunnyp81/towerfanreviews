---
import { getCollection } from 'astro:content';
import Base from '@layouts/Base.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { graph, breadcrumbSchema, canonical } from '@lib/seo';

const articles = (await getCollection('articles')).filter((a) => !a.data.draft);
const guides = articles.filter((a) => a.data.kind === 'guide');
const crumbs = [{ name: 'Home', url: '/' }, { name: 'Guides', url: '/guides/' }];
const schema = graph(breadcrumbSchema(crumbs.map((c) => ({ name: c.name, url: canonical(c.url) }))));
---
<Base title="Tower Fan Guides & Advice" description="Practical tower fan guides: running costs, cleaning, noise fixes, bladeless vs bladed, and how to get the most cooling from your fan." path="/guides/" schema={schema}>
  <section class="bg-breeze-mesh border-b border-breeze-100">
    <div class="mx-auto max-w-6xl px-4 pt-6 pb-10">
      <Breadcrumbs crumbs={crumbs} />
      <h1 class="mt-5 text-4xl sm:text-5xl">Tower fan guides &amp; advice</h1>
      <p class="mt-4 text-lg text-ink-500 max-w-2xl">No-nonsense answers to the questions people actually ask about tower fans, from running costs to cleaning, noise and getting more cooling for your money.</p>
    </div>
  </section>
  <section class="mx-auto max-w-6xl px-4 py-12">
    {guides.length === 0 ? (
      <p class="text-ink-500">Guides coming soon.</p>
    ) : (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {guides.map((g) => (
          <a href={`/${g.id}/`} class="group rounded-2xl border border-breeze-100 bg-white p-6 card-lift flex flex-col">
            <span class="grid place-items-center w-11 h-11 rounded-xl bg-breeze-50 text-breeze-600 mb-4"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg></span>
            <h2 class="text-xl leading-snug">{g.data.title}</h2>
            <p class="mt-2 text-sm text-ink-500 flex-1">{g.data.description}</p>
            <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-breeze-700 group-hover:text-heat-700">Read guide →</span>
          </a>
        ))}
      </div>
    )}
  </section>
</Base>
